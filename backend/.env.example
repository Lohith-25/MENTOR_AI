# MongoDB Connection Configuration
# Get your connection string from MongoDB Atlas Dashboard

# ============================================
# MONGODB SETUP INSTRUCTIONS
# ============================================
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a free M0 cluster (no credit card needed)
# 3. Click "Connect" on your cluster
# 4. Choose "Drivers" > "Python" > "3.6 or later"
# 5. Copy the connection string and paste below
# 6. Replace <password> with your database password
# ============================================

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name
MONGODB_URI=mongodb+srv://username:password@mentor-ai.xxxxx.mongodb.net/mentor_ai?retryWrites=true&w=majority

# Database name (collections will be created automatically)
MONGODB_DB_NAME=mentor_ai

# Flask Configuration (optional)
FLASK_ENV=development
FLASK_DEBUG=True
